<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_budget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/budget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Budget • Monthly"
            android:textColor="#E5E5E5"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/budget_period_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_toggle_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="Monthly"
            android:textColor="#DDDDDD"
            android:textSize="10sp" />

        <ImageView
            android:id="@+id/toggle_budget_visibility"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="6dp"
            android:contentDescription="Toggle budget visibility"
            android:src="@drawable/ic_visibility_on" />
    </LinearLayout>

    <TextView
        android:id="@+id/budget_last_updated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="--"
        android:textColor="#7D7D7D"
        android:textSize="9sp" />

    <LinearLayout
        android:id="@+id/budget_empty_group"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/budget_empty_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You currently don't have any budgets."
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/budget_content_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp">

                <ImageView
                    android:id="@+id/budget_ring"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/budget_percent_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="0%"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Spent"
                    android:textColor="#9E9E9E"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/budget_spent_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 ETB"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Budget"
                    android:textColor="#9E9E9E"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/budget_limit_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 ETB"
                    android:textColor="#D0D0D0"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/budget_category_bar"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/category_bar_background"
            android:scaleType="fitXY" />

        <LinearLayout
            android:id="@+id/budget_category_row_0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/budget_category_dot_0"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/category_dot" />

            <TextView
                android:id="@+id/budget_category_name_0"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Category"
                android:textColor="#CECECE"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/budget_category_amount_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 ETB"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/budget_category_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/budget_category_dot_1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/category_dot" />

            <TextView
                android:id="@+id/budget_category_name_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Category"
                android:textColor="#CECECE"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/budget_category_amount_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 ETB"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/budget_category_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/budget_category_dot_2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/category_dot" />

            <TextView
                android:id="@+id/budget_category_name_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Category"
                android:textColor="#CECECE"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/budget_category_amount_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 ETB"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
